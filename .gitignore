# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
# Monorepo: patterns below are unanchored (no leading slash) so they apply inside
# every sub-project folder, not just the repo root.

# dependencies (all sub-projects)
node_modules/
.pnp
.pnp.js

# local env files — do not commit any .env files, except .env.example
.env
.env.local
.env*.local

# backend (Next.js / Prisma)
backend/.next/
backend/out/
backend/next-env.d.ts
backend/generated/prisma/
backend/*.tsbuildinfo

# mobile-app (Expo / React Native) — managed workflow, native projects are
# regenerated via `expo prebuild`/`expo run:ios`, not hand-edited or committed
mobile-app/.expo/
mobile-app/ios/
mobile-app/android/

# whatsapp-service (Node.js / Baileys / Prisma)
whatsapp-service/dist/
whatsapp-service/generated/prisma/
whatsapp-service/*.tsbuildinfo

# telegram-service (Node.js / grammY)
telegram-service/dist/
telegram-service/*.tsbuildinfo

# testing
coverage/

# SSH — config and keys live in ~/.ssh outside this repo and must never be
# committed; these patterns are a defensive backstop in case one ever ends up
# inside the working tree (e.g. copied in by mistake).
.ssh/
id_rsa*
id_ed25519*
*.ppk

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# vercel
.vercel

# typescript
*.tsbuildinfo

# idea files
.idea

notebook/data