# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Prisma — this project uses a cloud Postgres instance (Neon), not a local DB.
# Get the real connection string from a teammate or the Neon dashboard.
# https://www.prisma.io/docs/reference/database-reference/connection-urls#env
DATABASE_URL="postgresql://<user>:<password>@<host>.neon.tech/<database>?sslmode=require&channel_binding=require"

# Shared secret checked on every request from mobile-app, whatsapp-service,
# and telegram-service (sent as the `x-api-key` header). Generate any long
# random string. Authenticates *services* (trusted infra calling this API at
# all) — distinct from JWT_SECRET below, which authenticates *which student*.
SHARED_API_KEY="<generate-a-long-random-string>"

# Signs/verifies mobile-app login session tokens (auth.register/auth.login
# issue them, auth.me verifies them) — generate a long random string
# (32+ chars), e.g. `openssl rand -base64 48`.
JWT_SECRET="<generate-a-long-random-string, 32+ chars>"

# MAIA Router (OpenAI-compatible gateway) — used only for turning a risk score
# into a plain-language explanation. Optional in dev: unset means
# explainRisk() falls back to a canned explanation instead of failing.
MAIA_API_KEY=""
MAIA_BASE_URL="https://router.maia.id/v1"

# whatsapp-service's localhost-only internal trigger server (same VPS,
# never proxied by Nginx) — used by reminders.triggerNow so mobile-app can
# fire an immediate reminder run for testing. Defaults to whatsapp-service's
# own INTERNAL_PORT default (4001); only change if that port is overridden.
WHATSAPP_SERVICE_URL="http://localhost:4001"

# telegram-service's localhost-only internal trigger server (same VPS) —
# used by reminders.triggerNow when channel is "telegram".
TELEGRAM_SERVICE_URL="http://localhost:4002"
