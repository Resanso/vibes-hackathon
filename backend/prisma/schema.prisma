// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Profile {
    phone String @id

    // Real auth (email + password) — added after phone/reminders identity
    // was already load-bearing everywhere else (RiskEntry, LoanTracking,
    // whatsapp/telegram-service all key off `phone`), so `phone` stays the
    // primary/foreign key throughout rather than migrating everything to a
    // generated id. `register` collects both; `login` looks up by email,
    // verifies passwordHash, then every subsequent call still keys off
    // phone exactly as before auth existed.
    email        String  @unique
    passwordHash String
    name         String?

    // Nullable/defaulted so `auth.register` can create this row before
    // FinancialSurvivalCheck runs — monthlyIncome/existingMonthlyDebt/
    // dependents start at 0 and get their real values from
    // profile.upsert, which also sets onboardingCompletedAt (see below).
    monthlyIncome       Int @default(0)
    existingMonthlyDebt Int @default(0)
    dependents          Int @default(0)
    // Self-reported daily-living costs (makan, transport, dsb) — NOT
    // existingMonthlyDebt (that's debt obligations, this is cost of living).
    // Used to compute disposable income for the risk score instead of raw
    // monthlyIncome, so someone with high income but also high living costs
    // isn't scored as if all their income were available for debt service.
    monthlyExpenses     Int @default(0)

    // Set once profile.upsert (FinancialSurvivalCheck) has actually run —
    // NOT inferable from monthlyIncome alone, since a genuinely-zero income
    // is a valid real answer, not "hasn't answered yet". mobile-app's boot
    // logic uses this (null vs set) to decide whether a logged-in student
    // goes straight to MainTabs or still needs to finish the onboarding
    // flow past registration.
    onboardingCompletedAt DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Which service sends this student their reminders/quick-consult
    // replies — "whatsapp" | "telegram", switchable any time from
    // mobile-app's Profil tab. Threat-detection (linked WhatsApp number
    // monitoring) is intentionally NOT gated by this — it stays
    // WhatsApp-only regardless of notification channel, since it's tied to
    // a separately-linked WhatsApp session, not the reminder/quick-consult
    // path. Defaults to "whatsapp" since that's the only channel that
    // existed before Telegram support was added.
    notificationChannel String  @default("whatsapp")
    // Set once via telegram-service's /start contact-share flow — required
    // before notificationChannel can be switched to "telegram" (see
    // profile.setChannel).
    telegramChatId      String? @unique

    riskEntries  RiskEntry[]
    chatMessages ChatMessage[]
}

model RiskEntry {
    id      String  @id @default(cuid())
    phone   String
    profile Profile @relation(fields: [phone], references: [phone])

    principal       Int
    interestRatePct Float
    serviceFee      Int
    tenorMonths     Int

    monthlyInstallment Int
    totalRepayment     Int
    riskScore          Int
    riskLabel          String
    explanation        String?

    // First installment due date (createdAt + 1 calendar month). Due dates
    // for installment N are derived as firstDueDate + (N-1) months, not
    // stored per-installment — there's no payment-tracking feature, so this
    // only ever answers "is an installment date coming up," never "was it paid."
    firstDueDate DateTime

    createdAt DateTime @default(now())

    // Set only once the user confirms they actually took this loan (not
    // every risk.assess call — many are just simulations). See LoanTracking.
    tracking LoanTracking?

    @@index([phone, createdAt])
}

// "State 2" of the product: after a loan is actually taken, track daily
// progress toward paying it off — separate from RiskEntry.firstDueDate's
// monthly due-date reminders, which only ever answer "is a date coming up,"
// never "did the user set money aside." One LoanTracking per RiskEntry the
// user explicitly marked as taken (mobile-app's "Saya Jadi Ambil Pinjaman
// Ini" button).
model LoanTracking {
    id          String @id @default(cuid())
    riskEntryId String @unique
    riskEntry   RiskEntry @relation(fields: [riskEntryId], references: [id])
    phone       String

    // ceil(monthlyInstallment / days-in-that-calendar-month), computed once
    // at tracking start — see src/server/logic/loanTracking.ts.
    dailyTargetAmount Int
    startedAt         DateTime @default(now())

    checkIns DailyCheckIn[]

    @@index([phone])
}

model DailyCheckIn {
    id             String @id @default(cuid())
    loanTrackingId String
    loanTracking   LoanTracking @relation(fields: [loanTrackingId], references: [id])

    // Calendar day this check-in is for, normalized to UTC midnight — not
    // createdAt, so a WhatsApp reply and an in-app tap for the same day
    // don't create two rows (see the unique constraint below).
    date      DateTime
    source    String // "app" | "whatsapp" | "telegram"
    createdAt DateTime @default(now())

    @@unique([loanTrackingId, date])
}

// Multi-turn AI Coach conversation history — free-text chat on
// whatsapp-service/telegram-service (replacing the old fixed /cek command
// format) feeds this back to src/server/ai/coachChat.ts on every turn so
// the model has context for follow-up questions. Every row is one message;
// `role` is "user" | "assistant" (no "system" rows stored — the system
// prompt is injected fresh each call, not persisted).
model ChatMessage {
    id        String   @id @default(cuid())
    phone     String
    profile   Profile  @relation(fields: [phone], references: [phone])
    role      String
    content   String
    createdAt DateTime @default(now())

    @@index([phone, createdAt])
}

// Scholarship listings ingested from public sources' WordPress REST APIs
// (see src/server/services/scholarshipScraper.ts) — surfaced in mobile-app's
// "Alternatif" tab as a non-repayable alternative to borrowing. Nera only
// links out to the source's own application page; it never fills out or
// submits an application on a student's behalf (see the design discussion
// in this feature's PR — auto-submitting third-party forms with no human
// review of essays/documents was explicitly ruled out).
model Scholarship {
    id String @id @default(cuid())

    title     String
    // Plain-text excerpt (HTML tags stripped at ingest time) — short enough
    // for a list-row description, not the full article body.
    summary   String
    sourceName String
    // Unique per source article — also the ingest upsert key, so re-running
    // the scraper updates an existing row instead of duplicating it.
    sourceUrl String @unique

    publishedAt DateTime
    scrapedAt   DateTime @default(now())

    @@index([publishedAt])
}
