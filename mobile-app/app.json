{
  "expo": {
    "name": "Nera",
    "slug": "nera",
    "scheme": "nera",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nera.app.dev",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSExceptionDomains": {
            "103.235.75.245": {
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSIncludesSubdomains": false
            }
          }
        }
      }
    },
    "android": {
      "package": "com.nera.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-asset"
    ]
  }
}
