# Expo inlines EXPO_PUBLIC_* vars at build time — these end up in the client
# bundle, so never put a real secret here beyond the shared API key backend
# already expects from trusted clients (mobile-app, whatsapp-service).

# Live VPS backend — see ../docs/deployment.md "Remote access"
EXPO_PUBLIC_BACKEND_URL="http://103.235.75.245:3000"

# Must match backend's SHARED_API_KEY exactly
EXPO_PUBLIC_SHARED_API_KEY="dev-local-shared-key-change-me"
