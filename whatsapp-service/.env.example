# backend's tRPC base URL — local dev default, use the VPS domain in prod
BACKEND_URL="http://localhost:3000"

# Must match backend's SHARED_API_KEY exactly — sent as x-api-key on every call
SHARED_API_KEY="<same value as backend's SHARED_API_KEY>"

# Own Postgres connection — stores Baileys session credentials/signal keys,
# LinkedNumber, and ThreatEvidence, not backend's business data. Can point at
# the same Postgres instance backend uses, but MUST use a different `schema`
# query param (e.g. `&schema=whatsapp`) — `prisma db push` is declarative and
# will try to DROP any table in the target schema that isn't in *this*
# project's schema.prisma. Sharing backend's default `public` schema without
# a separate `schema=` param will make db push try to drop backend's
# Profile/RiskEntry tables. A separate Postgres instance avoids this
# entirely, if available.
DATABASE_URL="postgresql://<user>:<password>@<host>/<database>?sslmode=require&schema=whatsapp"

# Daily cron schedule for the reminders.dueSoon check (cron syntax)
REMINDER_CRON="0 8 * * *"

# How many days ahead to look for upcoming installment due dates
REMINDER_WINDOW_DAYS="2"

# Localhost-only internal HTTP server (never proxied by Nginx) so backend's
# reminders.triggerNow can fire an immediate reminder run on demand.
INTERNAL_PORT="4001"
