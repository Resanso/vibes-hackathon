# backend's tRPC base URL — local dev default, use the VPS domain in prod
BACKEND_URL="http://localhost:3000"

# Must match backend's SHARED_API_KEY exactly — sent as x-api-key on every call
SHARED_API_KEY="<same value as backend's SHARED_API_KEY>"

# Own Postgres connection — stores Baileys session credentials/signal keys
# only (WhatsappCreds / WhatsappSignalKey), not business data. Can point at
# the same Postgres instance backend uses (different tables) or a separate one.
DATABASE_URL="postgresql://<user>:<password>@<host>/<database>?sslmode=require"

# Daily cron schedule for the reminders.dueSoon check (cron syntax)
REMINDER_CRON="0 8 * * *"

# How many days ahead to look for upcoming installment due dates
REMINDER_WINDOW_DAYS="2"
